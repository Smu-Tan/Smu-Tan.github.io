{% if site.data.experience %}
  <div class="experience-list">
    {% for item in site.data.experience %}
      <div class="experience-item">
        <div class="experience-mark">
          {% if item.logo %}
            <img
              class="experience-logo"
              src="{{ item.logo | prepend: 'assets/img/' | relative_url }}"
              alt="{{ item.logo_alt | default: item.organization }}"
              style="max-width: 110px; max-height: 54px; width: auto; height: auto;"
            >
          {% else %}
            <span>{{ item.mark }}</span>
          {% endif %}
        </div>
        <div class="experience-body">
          <div class="experience-heading">
            <div>
              <h3>{{ item.organization }}</h3>
              <p>{{ item.role }}</p>
            </div>
            <span>{{ item.period }}</span>
          </div>
          <p class="experience-location">{{ item.location }}</p>
        </div>
      </div>
    {% endfor %}
  </div>
{% endif %}
